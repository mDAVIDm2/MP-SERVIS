<?xml version="1.0" encoding="utf-8"?>
<!-- Явное разрешение HTTP к LAN (Nest). Дополняет android:usesCleartextTraffic на прошивках со строгой политикой. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
