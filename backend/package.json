{
  "name": "mp-servis-backend",
  "version": "1.0.0",
  "description": "MP-Servis API — NestJS + PostgreSQL для Business и Client",
  "scripts": {
    "db:create": "node scripts/create-db.js",
    "db:bootstrap": "ts-node -r tsconfig-paths/register scripts/bootstrap-local-schema.ts",
    "db:add-user-avatar-column": "node scripts/add-user-avatar-column.js",
    "db:add-staff-capabilities": "node scripts/add-staff-capabilities-columns.js",
    "seed:internal": "node scripts/seed-internal-admin.js",
    "fix:internal-null-email": "node scripts/fix-internal-operators-null-email.js",
    "clear-orders": "ts-node scripts/clear-orders.ts",
    "chats-find-duplicates": "ts-node -r tsconfig-paths/register scripts/chats-find-duplicates.ts",
    "test:bk": "ts-node -r tsconfig-paths/register scripts/smoke-organization-business-kind.ts",
    "seed:mp-servis-services": "ts-node -r tsconfig-paths/register scripts/seed-mp-servis-org-services.ts",
    "build": "nest build",
    "prestart": "node scripts/kill-port-3000.js",
    "start": "nest start",
    "predev": "node scripts/kill-port-3000.js",
    "dev": "nest start --watch",
    "prestart:dev": "node scripts/kill-port-3000.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d src/database/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/database/data-source.ts",
    "migration:run:prod": "node --env-file=.env scripts/run-migrations-prod.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "@types/nodemailer": "^7.0.11",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "firebase-admin": "^13.7.0",
    "luxon": "^3.7.2",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "sharp": "^0.34.5",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.17",
    "@types/luxon": "^3.7.1",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.3.0",
    "@types/passport-jwt": "^3.0.13",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.0"
  }
}
