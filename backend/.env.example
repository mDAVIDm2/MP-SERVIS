# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mp_servis

# Окружение: в production обязательны JWT_SECRET и INTERNAL_JWT_SECRET (см. bootstrap-env.ts).
# NODE_ENV=production

# JWT (клиент и бизнес-приложения)
JWT_SECRET=your-super-secret-key-change-in-production
# Отдельный секрет для Control Center (internal JWT). В production обязателен.
INTERNAL_JWT_SECRET=your-internal-secret-change-in-production
JWT_EXPIRES_IN=7d
# Короткоживущий access (если не задан — используется JWT_EXPIRES_IN)
JWT_ACCESS_EXPIRES_IN=15m
# Канал OTP: console | email | sms (sms пока заглушка). Новое имя — OTP_DELIVERY_PROVIDER; иначе читается AUTH_OTP_DELIVERY.
OTP_DELIVERY_PROVIDER=console
# AUTH_OTP_DELIVERY=console

# TTL кода и лимит попыток ввода (проверка только на сервере)
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
# Только локальная отладка (NODE_ENV !== production): вернуть код в JSON send-code как debug_otp.
# В production флаг игнорируется.
# OTP_DEBUG_RETURN_CODE=1

# Тестовые email/телефоны с особыми ролями (auth.service): только NODE_ENV !== production и ALLOW_TEST_AUTH=1
# ALLOW_TEST_AUTH=1

# CORS: для production — список origin через запятую (без "*"). Для Flutter Web укажите URL веб-сборки.
# Native mobile-приложения обычно не шлют Origin — CORS на них не влияет.
# ALLOWED_ORIGINS=https://app.example.ru,https://business.example.ru

# Email OTP: smtp (SMTP_*) или resend (EMAIL_API_KEY + EMAIL_FROM)
EMAIL_PROVIDER=smtp
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=re_xxxxxxxx
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM="MP-Servis <no-reply@your-verified-domain.com>"

# SMTP (если EMAIL_PROVIDER=smtp или не задан)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# Опционально: усложняет хэш refresh-токена в БД
# REFRESH_TOKEN_PEPPER=

# Порт API
PORT=3000

# FCM клиентское приложение (проект Firebase клиента, mp-servis-31b40):
# FIREBASE_SERVICE_ACCOUNT_PATH=secrets/mp-servis-31b40-....json
# FCM приложение СТО (отдельный проект, mp-servis-bissnes):
# FIREBASE_BUSINESS_SERVICE_ACCOUNT_PATH=secrets/mp-servis-bissnes-....json
# Либо JSON одной строкой: FIREBASE_SERVICE_ACCOUNT_JSON / FIREBASE_BUSINESS_SERVICE_ACCOUNT_JSON

# Первый суперадмин Control Center (см. autohub_control_center/README.md). Без этих переменных вход в панель невозможен.
INITIAL_SUPERADMIN_EMAIL=admin@example.com
INITIAL_SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Не коммитьте реальный .env. Секреты: JWT_SECRET, INTERNAL_JWT_SECRET, DATABASE_URL, SMTP_*, INITIAL_SUPERADMIN_PASSWORD,
# REFRESH_TOKEN_PEPPER, FIREBASE_*_JSON, API-ключи почты.
