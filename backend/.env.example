# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autohub

# JWT (для авторизации Business/Client)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
# Короткоживущий access (если не задан — используется JWT_EXPIRES_IN)
JWT_ACCESS_EXPIRES_IN=15m
# Канал OTP: console | email | sms (sms пока заглушка). Новое имя — OTP_DELIVERY_PROVIDER; иначе читается AUTH_OTP_DELIVERY.
OTP_DELIVERY_PROVIDER=console
# AUTH_OTP_DELIVERY=console

# TTL кода и лимит попыток ввода (проверка только на сервере)
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Email OTP: smtp (SMTP_*) или resend (EMAIL_API_KEY + EMAIL_FROM)
EMAIL_PROVIDER=smtp
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=re_xxxxxxxx
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM="AutoHub <no-reply@your-verified-domain.com>"

# SMTP (если EMAIL_PROVIDER=smtp или не задан)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# Опционально: усложняет хэш refresh-токена в БД
# REFRESH_TOKEN_PEPPER=

# Порт API
PORT=3000

# FCM клиентское приложение (проект Firebase клиента, mp-servis-31b40):
# FIREBASE_SERVICE_ACCOUNT_PATH=secrets/mp-servis-31b40-....json
# FCM приложение СТО (отдельный проект, mp-servis-bissnes):
# FIREBASE_BUSINESS_SERVICE_ACCOUNT_PATH=secrets/mp-servis-bissnes-....json
# Либо JSON одной строкой: FIREBASE_SERVICE_ACCOUNT_JSON / FIREBASE_BUSINESS_SERVICE_ACCOUNT_JSON

# Первый суперадмин Control Center (создаётся при первом запуске, если нет в БД)
INITIAL_SUPERADMIN_EMAIL=dpogosyan02@gmail.com
INITIAL_SUPERADMIN_PASSWORD=19872323Dd
