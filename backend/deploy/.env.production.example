# Скопируйте на сервер как /opt/mp-servis/api/.env (chmod 600).
# Замените все значения YOUR_* и пароли.

NODE_ENV=production
PORT=3000

# PostgreSQL (пользователь и БД создаются на сервере, см. SETUP_SERVER_RU.md)
DATABASE_URL=postgresql://mp_servis_app:YOUR_DB_PASSWORD@127.0.0.1:5432/mp_servis

# Сгенерируйте: openssl rand -base64 48 (отдельно для клиентских JWT и для Control Center)
JWT_SECRET=YOUR_LONG_RANDOM_SECRET
INTERNAL_JWT_SECRET=YOUR_OTHER_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=15m

# CORS для браузерных клиентов (Flutter Web и т.д.), через запятую, без "*"
ALLOWED_ORIGINS=https://app.ВАШ-ДОМЕН.ru,https://sto.ВАШ-ДОМЕН.ru
# Опционально: openssl rand -base64 32
# REFRESH_TOKEN_PEPPER=

# Публичный URL API (для ссылок в письмах и т.д.)
API_BASE_URL=https://api.ВАШ-ДОМЕН.ru/api/v1

# OTP: в проде — email или sms, не console
OTP_DELIVERY_PROVIDER=email
EMAIL_PROVIDER=smtp
EMAIL_FROM="MP-Servis <no-reply@ВАШ-ДОМЕН.ru>"
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Firebase (пути относительно WorkingDirectory или абсолютные)
# FIREBASE_SERVICE_ACCOUNT_PATH=/opt/mp-servis/api/secrets/firebase-client.json
# FIREBASE_BUSINESS_SERVICE_ACCOUNT_PATH=/opt/mp-servis/api/secrets/firebase-business.json

# Control Center: задайте сильный пароль при первом запуске
INITIAL_SUPERADMIN_EMAIL=admin@ВАШ-ДОМЕН.ru
INITIAL_SUPERADMIN_PASSWORD=YOUR_STRONG_PASSWORD
